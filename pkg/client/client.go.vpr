domain BoolWellFoundedOrder  {
  
  axiom bool_ax_bound {
    (forall bool1: Bool ::
      { (bounded(bool1): Bool) }
      (bounded(bool1): Bool))
  }
  
  axiom bool_ax_dec {
    (decreasing(false, true): Bool)
  }
}

